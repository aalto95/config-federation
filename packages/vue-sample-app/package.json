{
  "name": "vue-sample-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint && pnpm lint:prettier",
    "lint:fix": "pnpm lint:eslint:fix && pnpm lint:stylelint:fix && pnpm lint:prettier:fix",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:stylelint": "stylelint \"src/**/*.{vue,css,scss}\"",
    "lint:stylelint:fix": "stylelint \"src/**/*.{vue,css,scss}\" --fix",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "check": "pnpm lint && pnpm test"
  },
  "dependencies": {
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@config-federation/vue": "workspace:*",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "stylelint": "^17.9.0",
    "stylelint-config-property-sort-order-smacss": "^11.2.0",
    "vite": "^7.1.11",
    "vitest": "^4.1.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "typescript-eslint": "^8.59.0",
    "vitest-sonar-reporter": "^3.0.0"
  }
}
